# --- Postgres (campaign state) ---
POSTGRES_DB=auto_marketer
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- LLM for email generation (LM Studio / OpenAI-compatible) ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
CHAT_MODEL_NAME=local-model

# --- info-broker REST client ---
INFO_BROKER_BASE_URL=http://localhost:8000
INFO_BROKER_API_KEY=changeme

# --- this service's auth ---
AUTO_MARKETER_API_KEY=changeme

# --- SMTP (only required when --provider smtp) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
